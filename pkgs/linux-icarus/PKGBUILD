# Maintainer: Icarus-ArchOS
#
# Icarus kernel: mainline 7.1.2 stable, for Intel Iris Xe. 
# NOTE: This is a mainline stable kernel, not an LTS (longterm) release.
# It will require a rebuild sooner than an LTS kernel would. This is an
# accepted tradeoff.
#
# Config choices applied on top of `make defconfig`:
#   CONFIG_LOCALVERSION="-icarus"
#   CONFIG_DEBUG_INFO_BTF=y   (needs pahole, in makedepends below)
#   CONFIG_DRM_I915=y         
#   CONFIG_DRM_XE=m
#   CONFIG_ZRAM=y / CONFIG_ZSMALLOC=y
#   CONFIG_BTRFS_FS=y
#   CONFIG_BLK_DEV_NVME=y
#   CONFIG_NTSYNC=m           (Wine NT-sync primitives acceleration)
#   CONFIG_SCHED_CLASS_EXT=y  (sched_ext — required for Layer 6's scx-scheds)
#
# `make defconfig` is a deliberately lean baseline. See burn-in-checklist.md
# step 10 to ensure no critical drivers are missing for your exact hardware.

pkgbase=linux-icarus
pkgname=(linux-icarus linux-icarus-headers)
_srcname=linux-7.1.2
pkgver=7.1.2
pkgrel=1
arch=(x86_64)
url="https://www.kernel.org"
license=(GPL2)
makedepends=('bc' 'libelf' 'pahole' 'kmod' 'openssl' 'bison' 'flex' 'cpio' 'perl')
options=('!strip')
source=("https://www.kernel.org/pub/linux/kernel/v7.x/linux-7.1.2.tar.xz")
sha256sums=('37198c93727be247c9fb5309bb86cd5e496c61e5322cd8c4eca9476bb0b5883f')

prepare() {
  cd "${srcdir}/${_srcname}"

  make defconfig
  scripts/config --enable CONFIG_DEBUG_INFO_BTF
  scripts/config --enable CONFIG_DRM_I915
  scripts/config --module CONFIG_DRM_XE
  scripts/config --enable CONFIG_ZRAM
  scripts/config --enable CONFIG_ZSMALLOC
  scripts/config --enable CONFIG_BTRFS_FS
  scripts/config --enable CONFIG_BLK_DEV_NVME
  scripts/config --enable CONFIG_FUSE_FS
  scripts/config --enable CONFIG_BLK_DEV_INITRD
  scripts/config --module CONFIG_NTSYNC
  scripts/config --enable CONFIG_SCHED_CLASS_EXT
  scripts/config --enable CONFIG_BPF
  scripts/config --enable CONFIG_BPF_SYSCALL
  scripts/config --set-str CONFIG_LOCALVERSION "-icarus"
  make olddefconfig
}

build() {
  cd "${srcdir}/${_srcname}"
  make $MAKEFLAGS bzImage modules
}

_package() {
  local pkgdir="$1"
  cd "${srcdir}/${_srcname}"
  KERNELRELEASE=$(cat include/config/kernel.release)
  make INSTALL_MOD_PATH="$pkgdir/usr" modules_install
  install -Dm644 arch/x86/boot/bzImage "$pkgdir/boot/vmlinuz-linux-icarus"
  install -Dm644 arch/x86/boot/bzImage "$pkgdir/usr/lib/modules/${KERNELRELEASE}/vmlinuz"
  rm -f "$pkgdir/usr/lib/modules/${KERNELRELEASE}/build"
  rm -f "$pkgdir/usr/lib/modules/${KERNELRELEASE}/source"
}

package_linux-icarus() {
  pkgdesc="Icarus-ArchOS custom kernel (mainline 7.1.2 stable) for Intel Iris Xe"
  depends=('coreutils' 'kmod' 'linux-firmware')
  provides=('KERNEL_MODULES')

  _package "$pkgdir"
  cd "${srcdir}/${_srcname}"
  KERNELRELEASE=$(cat include/config/kernel.release)
  mkdir -p "$pkgdir/etc/mkinitcpio.d"
  cat > "$pkgdir/etc/mkinitcpio.d/linux-icarus.preset" << EOF
ALL_config="/etc/mkinitcpio.conf"
ALL_kver="/usr/lib/modules/${KERNELRELEASE}/vmlinuz"
PRESETS=('default')
default_image="/boot/initramfs-linux-icarus.img"
default_options=""
EOF
}

package_linux-icarus-headers() {
  pkgdesc="Headers and build files for the Icarus-ArchOS custom kernel"
  depends=('pahole')

  cd "${srcdir}/${_srcname}"
  KERNELRELEASE=$(cat include/config/kernel.release)
  local builddir="$pkgdir/usr/lib/modules/${KERNELRELEASE}/build"

  echo "Installing build files..."
  install -Dt "$builddir" -m644 .config Makefile Module.symvers System.map vmlinux
  install -Dt "$builddir/kernel" -m644 kernel/Makefile
  install -Dt "$builddir/arch/x86" -m644 arch/x86/Makefile
  cp -t "$builddir" -a scripts
  
  if [ -f tools/objtool/objtool ]; then
    install -Dt "$builddir/tools/objtool" tools/objtool/objtool
  fi
  if [ -f tools/bpf/resolve_btfids/resolve_btfids ]; then
    install -Dt "$builddir/tools/bpf/resolve_btfids" tools/bpf/resolve_btfids/resolve_btfids
  fi

  echo "Installing headers..."
  cp -t "$builddir" -a include
  cp -t "$builddir/arch/x86" -a arch/x86/include
  install -Dt "$builddir/arch/x86/kernel" -m644 arch/x86/kernel/asm-offsets.s

  echo "Installing KConfig files..."
  find . -name 'Kconfig*' -exec install -Dm644 {} "$builddir/{}" \;

  echo "Removing unneeded architectures..."
  local arch
  for arch in "$builddir"/arch/*/; do
      [[ $arch = */x86/ ]] && continue
      rm -r "$arch"
  done

  echo "Removing documentation..."
  rm -rf "$builddir/Documentation"

  echo "Removing broken symlinks..."
  find -L "$builddir" -type l -delete

  echo "Removing loose objects..."
  find "$builddir" -type f -name '*.o' -delete

  ln -s build "$pkgdir/usr/lib/modules/${KERNELRELEASE}/source"
}
