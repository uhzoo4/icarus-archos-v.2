# ~/.config/dunst/dunstrc
# Icarus-ArchOS — Intelligent Darkness notification styling
# Glassmorphic titanium-framed popups with blur (requires layerrule in hyprland.conf).

[global]
    monitor = 0
    follow = mouse
    width = 340
    height = (0, 300)
    origin = top-right
    offset = 16x52
    indicate_hidden = yes
    transparency = 0
    notification_limit = 5
    separator_height = 2
    separator_color = "#9aa0a620"
    padding = 16
    horizontal_padding = 16
    text_icon_padding = 16
    frame_width = 2
    frame_color = "#9aa0a628"
    gap_size = 6
    sort = yes
    idle_threshold = 120

    font = JetBrains Mono Nerd Font 11
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 24
    max_icon_size = 48
    icon_theme = Papirus-Dark
    enable_recursive_icon_lookup = true

    corner_radius = 12

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 4

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#0a0a0aCC"
    foreground = "#C7CACD"
    frame_color = "#9aa0a620"
    highlight = "#4A6D8C"
    timeout = 5

[urgency_normal]
    background = "#0a0a0aDD"
    foreground = "#C7CACD"
    frame_color = "#9aa0a630"
    highlight = "#4A6D8C"
    timeout = 8

[urgency_critical]
    background = "#0a0a0aEE"
    foreground = "#C7CACD"
    frame_color = "#C96B6B88"
    highlight = "#C96B6B"
    timeout = 0
